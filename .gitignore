# 构建目录（产物不提交）
build/
build_x64/
*.exe
*.pdb
*.obj

# 构建目录内的链接库（third_party 预编译包除外，见下方）
build/**/*.dll
build/**/*.lib
build_x64/**/*.dll
build_x64/**/*.lib
# Python
__pycache__/
*.pyc
.venv/
venv/

# IDE / 工具
.vs/
.vscode/
*.user
*.suo
*.sln.docstates

# Cursor IDE 本地配置（skills、会话缓存等，不上传 GitHub）
.cursor/

# 日志与临时文件
docs/log_*.txt
*.log
*.part
frame.rgb

# llama.cpp 源码（可选；预编译包见 llama_prebuilt/）
third_party/llama.cpp/build/

# 第三方下载/解压缓存
third_party/ffmpeg/x64_download.zip
third_party/ffmpeg/_x64_extract/

# 大文件（按需调整）
tests/*.mp4
models/**/*.bin
models/**/*.gguf
models/**/*.onnx

# ONNX Runtime 预编译二进制（含 >100MB DLL，GitHub 禁止；本机保留在 third_party）
third_party/onnxruntime/x64/bin/
third_party/onnxruntime/x64/lib/
third_party/onnxruntime/x86/
third_party/onnxruntime/_cache/

# OpenCV Debug 变体（>100MB，GitHub 禁止；Release 构建只需 opencv_world4120.*）
third_party/opencv/**/*d.dll
third_party/opencv/**/*d.lib

# 系统
Thumbs.db
Desktop.ini
